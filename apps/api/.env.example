PORT=4000
FRONTEND_URL=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5440/autoig?schema=public
REDIS_URL=redis://localhost:6380
JWT_SECRET=replace-me
WEBHOOK_VERIFY_TOKEN=replace-me

# Meta / Facebook app credentials (only needed if using Facebook Login for Business flow)
META_APP_ID=
META_APP_SECRET=
META_CONFIG_ID=

# Instagram Business Login app credentials (preferred; from Use case > API setup with Instagram login)
META_INSTAGRAM_APP_ID=
META_INSTAGRAM_APP_SECRET=

META_REDIRECT_URI=http://localhost:4000/instagram/oauth/callback
META_GRAPH_VERSION=v23.0
META_OAUTH_SCOPES=instagram_business_basic,instagram_business_manage_messages,instagram_business_manage_comments
MOCK_INSTAGRAM_CONNECT=true
